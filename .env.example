# ─────────────────────────────────────────────────────────────
# Swiggy Voice Agent — environment template
# Copy to .env and fill in. Required keys are marked REQUIRED.
# ─────────────────────────────────────────────────────────────

# ── Core (REQUIRED) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...              # REQUIRED — console.anthropic.com
TWILIO_ACCOUNT_SID=AC...                  # REQUIRED for voice/WhatsApp
TWILIO_AUTH_TOKEN=...                     # REQUIRED for voice/WhatsApp
TWILIO_PHONE_NUMBER=+1...                 # your Twilio voice number
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # sandbox default

# ── Text-to-speech ───────────────────────────────────────────
ELEVENLABS_API_KEY=...                    # optional — falls back to Twilio Polly if unset
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # default voice

# ── Runtime ──────────────────────────────────────────────────
DEMO_MODE=true                            # true = mock data; false = live Swiggy MCP
BASE_URL=http://localhost:8000            # update to your Railway URL after deploy
PORT=8000

# ── Models (optional — these are the defaults) ───────────────
AGENT_MODEL=claude-sonnet-5               # chat/WhatsApp brain — best value/quality for ordering
VOICE_MODEL=claude-haiku-4-5              # live phone calls — cheapest + fastest
CHAT_THINKING=disabled                    # Sonnet 5 thinks by default; disabled saves tokens. "adaptive" re-enables
CHAT_MAX_TOKENS=1024                      # per-reply output cap for chat

# ── Timeouts (optional) ──────────────────────────────────────
VOICE_API_TIMEOUT_SECS=7.0                # per-call Anthropic API deadline (voice)
CHAT_API_TIMEOUT_SECS=30.0                # per-call Anthropic API deadline (chat)
VOICE_AGENT_TIMEOUT_SECS=16.0             # background voice-agent deadline
VOICE_RESULT_MAX_POLLS=8                  # voice /result poll attempts

# ── Delivery address (optional — auto-fetched from Swiggy when live) ──
DEFAULT_ADDRESS_ID=                       # fallback if live address fetch fails
DEFAULT_ADDRESS_LABEL=Home
DEFAULT_ADDRESS_AREA=
DEFAULT_ADDR_TTL=600                      # address cache TTL (seconds)

# ── Swiggy MCP tokens (live mode) ────────────────────────────
# Product is Instamart-only, so only SWIGGY_IM_TOKEN is needed.
# Prefer running `python3 swiggy_auth.py login im` locally; for
# Railway, paste the token from `python3 swiggy_auth.py export-env`.
SWIGGY_IM_TOKEN=
SWIGGY_FOOD_TOKEN=
SWIGGY_DINEOUT_TOKEN=

# ── Voice-note transcription (optional fallbacks) ────────────
DEEPGRAM_API_KEY=                         # 2nd-choice STT (best for Indian accents)
OPENAI_API_KEY=                           # 3rd-choice STT (Whisper)

# ── Order history (optional) ─────────────────────────────────
ORDER_HISTORY_DB=                         # path to sqlite order-history DB

# ── Token health monitor (optional) ──────────────────────────
SWIGGY_HEALTH_URL=                        # /health endpoint for the token-health check
SWIGGY_TOKEN_KEYS=im                      # which scopes to monitor
SWIGGY_TOKEN_WARN_HOURS=24                # warn when a token expires within N hours
